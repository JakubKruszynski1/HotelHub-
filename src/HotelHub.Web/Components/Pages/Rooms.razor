@page "/rooms"
@inject BookingFacade Facade

<PageTitle>HotelHub — pokoje</PageTitle>

<h1>Pokoje</h1>

<div class="card mb-3">
    <div class="card-header">Sprawdź dostępność w terminie</div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label" for="from">Data przyjazdu</label>
                <input id="from" type="date" class="form-control" @bind="_from" />
            </div>
            <div class="col-auto">
                <label class="form-label" for="to">Data wyjazdu</label>
                <input id="to" type="date" class="form-control" @bind="_to" />
            </div>
            <div class="col-auto">
                <button class="btn btn-primary" @onclick="CheckAvailability">Sprawdź dostępność</button>
            </div>
            @if (_stay is not null)
            {
                <div class="col-auto">
                    <button class="btn btn-outline-secondary" @onclick="ClearFilter">Wyczyść filtr</button>
                </div>
            }
        </div>
        @if (_error is not null)
        {
            <div class="alert alert-danger mt-3 mb-0">@_error</div>
        }
        @if (_stay is not null)
        {
            <div class="alert alert-info mt-3 mb-0">
                Dostępność w terminie <strong>@_stay</strong>:
                wolne pokoje: <strong>@_availableNumbers!.Count</strong> z @Facade.Rooms.Count.
            </div>
        }
    </div>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Nr</th>
            <th>Typ</th>
            <th>Osoby</th>
            <th>Cena/noc</th>
            @if (_stay is not null)
            {
                <th>Dostępność</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Facade.Rooms.OrderBy(r => r.Number))
        {
            <tr>
                <td>@room.Number</td>
                <td>@room.TypeName</td>
                <td>@room.Capacity</td>
                <td>@room.GetPrice()</td>
                @if (_stay is not null)
                {
                    <td>
                        @if (_availableNumbers!.Contains(room.Number))
                        {
                            <span class="badge bg-success">wolny</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">zajęty</span>
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

@code {
    private DateTime _from = DateTime.Today.AddDays(1);
    private DateTime _to = DateTime.Today.AddDays(4);
    private DateRange? _stay;
    private HashSet<int>? _availableNumbers;
    private string? _error;

    private void CheckAvailability()
    {
        _error = null;
        _stay = null;
        _availableNumbers = null;

        try
        {
            var stay = new DateRange(_from, _to);
            _availableNumbers = Facade.GetAvailableRooms(stay).Select(r => r.Number).ToHashSet();
            _stay = stay;
        }
        catch (ArgumentException exception)
        {
            _error = exception.Message;
        }
    }

    private void ClearFilter()
    {
        _stay = null;
        _availableNumbers = null;
        _error = null;
    }
}
