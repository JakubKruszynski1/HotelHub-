@page "/"
@inject IBookingFacade Facade

<PageTitle>Hotel Pod Różą — HotelHub</PageTitle>

<section class="hero">
    <div class="hero-inner">
        <h1>Hotel Pod Różą</h1>
        <p class="hero-sub">Elegancki wypoczynek w sercu Krakowa — @Facade.Rooms.Count(r => !r.IsOutOfService) pokoi czeka na Ciebie.</p>
        <a class="btn btn-gold btn-lg" href="/rooms">Zobacz pokoje</a>
    </div>
</section>

<p class="muted">Pełna strona główna z wyszukiwarką i wyróżnionymi pokojami — w przygotowaniu.</p>
