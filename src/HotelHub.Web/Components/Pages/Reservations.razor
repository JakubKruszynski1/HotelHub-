@page "/reservations"
@inject BookingFacade Facade

<PageTitle>HotelHub — rezerwacje</PageTitle>

<h1>Rezerwacje</h1>
<p class="text-muted">
    Dostępność akcji wynika ze stanu rezerwacji (wzorzec State) — przycisk jest widoczny
    tylko wtedy, gdy operacja jest dozwolona.
</p>

@if (_message is not null)
{
    <div class="alert @_messageCss">@_message</div>
}

@if (Facade.Reservations.Count == 0)
{
    <p>Brak rezerwacji — utwórz pierwszą w zakładce <a href="reservations/new">Nowa rezerwacja</a>.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Gość</th>
                <th>Pokój (z usługami)</th>
                <th>Termin</th>
                <th>Cena</th>
                <th>Stan</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reservation in Facade.Reservations)
            {
                <tr>
                    <td><code>@reservation.ShortId</code></td>
                    <td>@reservation.Guest.FullName</td>
                    <td>@reservation.Room.GetDescription()</td>
                    <td>@reservation.Stay</td>
                    <td>@reservation.TotalPrice</td>
                    <td><span class="@StatusBadge.CssClass(reservation)">@StatusBadge.Label(reservation)</span></td>
                    <td>
                        @if (reservation.CanConfirm(Actor))
                        {
                            <button class="btn btn-sm btn-primary me-1 mb-1"
                                    @onclick="() => Confirm(reservation)">Potwierdź</button>
                        }
                        @if (reservation.CanPay(Actor))
                        {
                            <button class="btn btn-sm btn-success me-1 mb-1"
                                    @onclick="() => Pay(reservation)">Opłać</button>
                        }
                        @if (reservation.CanCheckIn(Actor))
                        {
                            <button class="btn btn-sm btn-info me-1 mb-1"
                                    @onclick="() => CheckIn(reservation)">Zamelduj</button>
                        }
                        @if (reservation.CanCheckOut(Actor))
                        {
                            <button class="btn btn-sm btn-dark me-1 mb-1"
                                    @onclick="() => CheckOut(reservation)">Wymelduj</button>
                        }
                        @if (reservation.CanCancel(Actor))
                        {
                            <button class="btn btn-sm btn-outline-danger me-1 mb-1"
                                    @onclick="() => Cancel(reservation)">Anuluj</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private static readonly ActorContext Actor = ActorContext.System;

    private string? _message;
    private string _messageCss = "alert-success";

    private void Confirm(Reservation reservation) => Apply(Facade.ConfirmReservation(reservation));

    private void Pay(Reservation reservation) => Apply(Facade.PayReservation(reservation));

    private void Cancel(Reservation reservation) => Apply(Facade.CancelReservation(reservation));

    private void CheckIn(Reservation reservation) => Apply(Facade.CheckIn(reservation));

    private void CheckOut(Reservation reservation) => Apply(Facade.CheckOut(reservation));

    private void Apply(OperationResult result)
    {
        _message = result.Message;
        _messageCss = result.Success ? "alert-success" : "alert-warning";
    }
}
