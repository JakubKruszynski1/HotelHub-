@page "/events"
@inject WebNotifier Notifier

<PageTitle>HotelHub — zdarzenia</PageTitle>

<h1>Zdarzenia</h1>
<p class="text-muted">
    Panel powiadomień (wzorzec Observer) — każdy wpis pochodzi z obserwatora
    <code>WebNotifier</code> zarejestrowanego obok powiadomień konsolowych i <code>audit.log</code>.
</p>

@if (Notifier.Events.Count == 0)
{
    <p>Brak zdarzeń — wykonaj dowolną operację na rezerwacji.</p>
}
else
{
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th style="width: 10rem">Czas</th>
                <th style="width: 8rem">Kanał</th>
                <th>Zdarzenie</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in Notifier.Events.OrderByDescending(e => e.Timestamp))
            {
                <tr>
                    <td><code>@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</code></td>
                    <td><span class="badge @ChannelCss(entry.Channel)">[@entry.Channel]</span></td>
                    <td>@entry.Message</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private static string ChannelCss(string channel) => channel switch
    {
        "E-MAIL" => "bg-info text-dark",
        "RECEPCJA" => "bg-warning text-dark",
        "AUDYT" => "bg-secondary",
        _ => "bg-light text-dark"
    };
}
