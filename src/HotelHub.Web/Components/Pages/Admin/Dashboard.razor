@page "/admin"
@layout HotelHub.Web.Components.Layout.AdminLayout
@attribute [Authorize(Roles = "Reception")]
@inject IBookingFacade Facade
@inject CurrentUserContext UserContext
@inject ToastService Toasts

<PageTitle>Pulpit dnia — HotelHub</PageTitle>

<h2>Pulpit dnia · @Fmt.Date(DateTime.Today)</h2>

<div class="grid grid-4" style="margin-top:1rem">
    <div class="stat-tile">
        <div class="stat-value">@Pending.Count</div>
        <div class="stat-label"><a href="/admin/reservations">rezerwacje oczekujące →</a></div>
    </div>
    <div class="stat-tile">
        <div class="stat-value">@ArrivalsToday.Count</div>
        <div class="stat-label">przyjazdy dziś</div>
    </div>
    <div class="stat-tile">
        <div class="stat-value">@DeparturesToday.Count</div>
        <div class="stat-label">wyjazdy dziś</div>
    </div>
    <div class="stat-tile">
        <div class="stat-value">@OccupancyPercent%</div>
        <div class="stat-label">obłożenie dziś (@OccupiedTodayCount/@ServiceableRoomCount pokoi)</div>
    </div>
</div>

<div class="grid grid-2" style="margin-top:1.25rem">
    <div class="card">
        <h3 class="card-title">Przyjazdy dziś</h3>
        @if (ArrivalsToday.Count == 0)
        {
            <p class="muted small" style="margin:0">Brak przyjazdów zaplanowanych na dziś.</p>
        }
        else
        {
            <table class="data-table">
                <tbody>
                    @foreach (var reservation in ArrivalsToday)
                    {
                        <tr>
                            <td><strong>@reservation.ReservationNumber</strong></td>
                            <td>@reservation.Guest.FullName</td>
                            <td>Pokój @reservation.BaseRoom.Number</td>
                            <td>
                                <button class="btn btn-teal btn-sm" @onclick="() => CheckIn(reservation)">
                                    Zamelduj
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="card">
        <h3 class="card-title">Wyjazdy dziś</h3>
        @if (DeparturesToday.Count == 0)
        {
            <p class="muted small" style="margin:0">Brak wyjazdów zaplanowanych na dziś.</p>
        }
        else
        {
            <table class="data-table">
                <tbody>
                    @foreach (var reservation in DeparturesToday)
                    {
                        <tr>
                            <td><strong>@reservation.ReservationNumber</strong></td>
                            <td>@reservation.Guest.FullName</td>
                            <td>Pokój @reservation.BaseRoom.Number</td>
                            <td>
                                <button class="btn btn-primary btn-sm" @onclick="() => CheckOut(reservation)">
                                    Wymelduj
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card" style="margin-top:1.25rem">
    <h3 class="card-title">Oczekujące na akceptację</h3>
    @if (Pending.Count == 0)
    {
        <p class="muted small" style="margin:0">Wszystkie rezerwacje zostały obsłużone. 🎉</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Numer</th><th>Gość</th><th>Pokój</th><th>Termin</th><th>Kwota</th><th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reservation in Pending)
                {
                    <tr>
                        <td><strong>@reservation.ReservationNumber</strong></td>
                        <td>@reservation.Guest.FullName</td>
                        <td>@reservation.Room.GetDescription()</td>
                        <td>@Fmt.Range(reservation.Stay)</td>
                        <td class="price">@Fmt.Money(reservation.TotalPrice)</td>
                        <td class="actions">
                            <button class="btn btn-accent btn-sm" @onclick="() => Confirm(reservation)">Potwierdź</button>
                            <button class="btn btn-warn btn-sm" @onclick="() => _rejectTarget = reservation">Odrzuć</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<RejectModal Reservation="_rejectTarget"
             OnClose="() => _rejectTarget = null"
             OnReject="Reject" />

@code {
    private Reservation? _rejectTarget;

    private ActorContext Actor => UserContext.Actor;

    private IReadOnlyList<Reservation> Pending =>
        Facade.Reservations
            .Where(r => r.State is HotelHub.Behavioral.States.PendingState)
            .OrderBy(r => r.CreatedAt)
            .ToList();

    private IReadOnlyList<Reservation> ArrivalsToday =>
        Facade.Reservations
            .Where(r => r.State is HotelHub.Behavioral.States.PaidState && r.Stay.From == DateTime.Today)
            .OrderBy(r => r.BaseRoom.Number)
            .ToList();

    private IReadOnlyList<Reservation> DeparturesToday =>
        Facade.Reservations
            .Where(r => r.State is HotelHub.Behavioral.States.CheckedInState && r.Stay.To == DateTime.Today)
            .OrderBy(r => r.BaseRoom.Number)
            .ToList();

    private int ServiceableRoomCount => Facade.Rooms.Count(r => !r.IsOutOfService);

    private int OccupiedTodayCount =>
        Facade.Reservations
            .Where(r => r.BlocksRoom &&
                        r.Stay.From <= DateTime.Today && DateTime.Today < r.Stay.To)
            .Select(r => r.BaseRoom.Number)
            .Distinct()
            .Count();

    private int OccupancyPercent =>
        ServiceableRoomCount == 0 ? 0 : (int)Math.Round(100.0 * OccupiedTodayCount / ServiceableRoomCount);

    private void Confirm(Reservation reservation) => Toasts.FromResult(Facade.ConfirmReservation(reservation));

    private void CheckIn(Reservation reservation) => Toasts.FromResult(Facade.CheckIn(reservation));

    private void CheckOut(Reservation reservation) => Toasts.FromResult(Facade.CheckOut(reservation));

    private void Reject(string reason)
    {
        if (_rejectTarget is not null)
        {
            Toasts.FromResult(Facade.RejectReservation(_rejectTarget, reason));
        }

        _rejectTarget = null;
    }
}
