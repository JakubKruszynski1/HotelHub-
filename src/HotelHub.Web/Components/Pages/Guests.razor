@page "/guests"
@inject BookingFacade Facade

<PageTitle>HotelHub — goście</PageTitle>

<h1>Goście</h1>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Zarejestrowani goście (@Facade.Guests.Count)</div>
            <div class="card-body">
                @if (Facade.Guests.Count == 0)
                {
                    <p class="text-muted mb-0">Brak zarejestrowanych gości.</p>
                }
                else
                {
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Imię</th>
                                <th>Nazwisko</th>
                                <th>E-mail</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var guest in Facade.Guests)
                            {
                                <tr>
                                    <td>@guest.FirstName</td>
                                    <td>@guest.LastName</td>
                                    <td>@guest.Email</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Rejestracja gościa</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label" for="firstName">Imię *</label>
                    <input id="firstName" class="form-control" maxlength="@Guest.MaxNameLength" @bind="_firstName" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="lastName">Nazwisko *</label>
                    <input id="lastName" class="form-control" maxlength="@Guest.MaxNameLength" @bind="_lastName" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="email">E-mail *</label>
                    <input id="email" type="email" class="form-control" @bind="_email" />
                </div>
                <button class="btn btn-primary" @onclick="Register">Zarejestruj</button>

                @if (_success is not null)
                {
                    <div class="alert alert-success mt-3 mb-0">@_success</div>
                }
                @if (_error is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">@_error</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string _email = string.Empty;
    private string? _success;
    private string? _error;

    private void Register()
    {
        _success = null;
        _error = null;

        try
        {
            var guest = Facade.RegisterGuest(_firstName, _lastName, _email);
            _success = $"Zarejestrowano gościa: {guest.FullName} <{guest.Email}>.";
            _firstName = string.Empty;
            _lastName = string.Empty;
            _email = string.Empty;
        }
        catch (Exception exception) when (exception is ArgumentException or InvalidOperationException)
        {
            _error = exception.Message;
        }
    }
}
