@page "/data"
@inject BookingFacade Facade

<PageTitle>HotelHub — dane</PageTitle>

<h1>Dane (JSON)</h1>
<p class="text-muted">
    Zapis i odczyt stanu aplikacji (pokoje, goście, rezerwacje) do pliku
    <code>hotelhub-data.json</code> w katalogu aplikacji — nazwa pliku jest stała
    i nigdy nie pochodzi od użytkownika.
</p>

<div class="card" style="max-width: 40rem">
    <div class="card-body">
        <button class="btn btn-primary me-2" @onclick="Save">Zapisz dane do JSON</button>
        <button class="btn btn-outline-primary" @onclick="Load">Wczytaj dane z JSON</button>

        @if (_message is not null)
        {
            <div class="alert @_messageCss mt-3 mb-0">@_message</div>
        }
    </div>
</div>

@code {
    private string? _message;
    private string _messageCss = "alert-success";

    private void Save()
    {
        try
        {
            Facade.SaveData();
            _message = $"Zapisano dane: pokoje: {Facade.Rooms.Count}, goście: {Facade.Guests.Count}, " +
                       $"rezerwacje: {Facade.Reservations.Count}.";
            _messageCss = "alert-success";
        }
        catch (Exception exception) when (exception is IOException or UnauthorizedAccessException)
        {
            _message = $"Nie udało się zapisać danych: {exception.Message}";
            _messageCss = "alert-danger";
        }
    }

    private void Load()
    {
        if (Facade.LoadData())
        {
            _message = $"Wczytano dane: pokoje: {Facade.Rooms.Count}, goście: {Facade.Guests.Count}, " +
                       $"rezerwacje: {Facade.Reservations.Count}.";
            _messageCss = "alert-success";
        }
        else
        {
            _message = "Nie udało się wczytać danych — brak pliku lub plik jest uszkodzony.";
            _messageCss = "alert-danger";
        }
    }
}
