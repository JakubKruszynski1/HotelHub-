@implements IDisposable
@inject ToastService Toasts

@* Kontener toastów sukces/błąd — umieszczany w obu layoutach. *@

<div class="toast-host">
    @foreach (var toast in Toasts.Toasts)
    {
        <div class="toast @(toast.IsSuccess ? "toast-success" : "toast-error")">@toast.Message</div>
    }
</div>

@code {
    protected override void OnInitialized() => Toasts.Changed += OnChanged;

    private void OnChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Toasts.Changed -= OnChanged;
}
