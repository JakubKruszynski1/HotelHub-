@* Rekurencyjny węzeł drzewa struktury hotelu (Composite: HotelBranch = gałąź, Room = liść). *@

@if (Component is HotelBranch branch)
{
    <details open>
        <summary class="fw-bold py-1">🏨 @branch.Name</summary>
        <ul class="list-unstyled ms-4 mb-1">
            @foreach (var child in branch.Children)
            {
                <li><HotelTreeNode Component="child" /></li>
            }
        </ul>
    </details>
}
else if (Component is Room room)
{
    <span class="py-1 d-inline-block">🛏 @room.GetDescription() — @room.GetPrice()/noc</span>
}

@code {
    [Parameter, EditorRequired]
    public IHotelComponent Component { get; set; } = default!;
}
